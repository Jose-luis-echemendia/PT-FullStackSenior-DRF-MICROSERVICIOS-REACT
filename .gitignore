# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg-info/
*.egg
MANIFEST

# ── Django ─────────────────────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# ── Tests / coverage ──────────────────────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.pytest_cache/
.hypothesis/

# ── Linting / type checking ───────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/
.dmypy.json

# ── Package managers (uv / Poetry) ────────────────────────────────────────────
# Lock files ARE committed — they pin reproducible builds.
# Only ignore tooling state dirs:
.pdm-python

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment variables ──────────────────────────────────────────────────────
# .env.example is committed; real env files are not.
.env
.env.*
!.env.example
.envrc

# ── Frontend (Vite + Bun + TypeScript) ────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo
# Vite local override files
*.local

# ── Docker volumes / data ─────────────────────────────────────────────────────
postgres-data/
rabbitmq-data/
mnesia/

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/
IMPLEMENTATION_PLAN.md

# ── OS / editor artefacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
