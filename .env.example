# ----------------------------------------------------------------------------
# Copy to .env  ->  `cp .env.example .env`  (defaults work out of the box)
# ----------------------------------------------------------------------------

# PostgreSQL (shared credentials, one database per service)
DB_USER=ecommerce
DB_PASSWORD=changeme

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Django
DJANGO_SECRET_KEY=dev-secret-change-in-prod
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*

# CORS (frontend + gateway origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Frontend
VITE_API_URL=http://localhost:8080/api
